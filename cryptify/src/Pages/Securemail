/* ── inline decrypt form inside card ── */
const DecryptInline = ({ email, onDecrypt }) => {
  const [key, setKey]     = useState("");
  const [show, setShow]   = useState(false);
  const [algo, setAlgo]   = useState(email.algo);
  const [err, setErr]     = useState("");

  const handle = () => {
    const { ok, result } = decryptText(email.encryptedBody, key, algo);
    if (ok) { onDecrypt(result); setErr(""); }
    else    setErr(result);
  };

  return (
    <div style={{ width: "100%", background: "#060910", border: "1px solid #1e2d40", borderRadius: 12, padding: "14px 16px" }}>
      <p className="mono" style={{ fontSize: 10, color: "#334155", fontWeight: 700, letterSpacing: "0.10em", marginBottom: 12 }}>

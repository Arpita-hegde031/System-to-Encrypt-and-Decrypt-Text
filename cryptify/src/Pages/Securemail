                <Icon n="mail" s={14} c="#0ea5e9" />
              </div>
              <span className="mono" style={{ fontSize: 11, color: "#64748b", fontWeight: 700 }}>NEW MESSAGE</span>
              <div style={{ marginLeft: "auto", display: "flex", gap: 6 }}>
                <button onClick={() => setShowCC(v => !v)} style={{
                  padding: "4px 10px", borderRadius: 8, border: "1px solid #1e2d40", background: "transparent",
                  fontFamily: "'JetBrains Mono',monospace", fontSize: 10, color: "#334155", cursor: "pointer",
                }}>
                  {showCC ? "HIDE CC" : "ADD CC"}
                </button>
              </div>
            </div>

            {/* To */}
            <TagInput label="To" icon="at" tags={to} setTags={setTo} placeholder="recipient@example.com — press Enter" />

            {/* CC */}
            {showCC && (
              <TagInput label="CC" icon="user" tags={cc} setTags={setCc} placeholder="cc@example.com — press Enter" />
            )}

            {/* Subject */}
            <div style={{ display: "flex", alignItems: "center", gap: 10, borderBottom: "1px solid #0f1e2e", padding: "12px 20px" }}>
              <div style={{ display: "flex", alignItems: "center", gap: 6, minWidth: 60 }}>
                <Icon n="tag" s={13} c="#334155" />
                <span style={{ fontSize: 12, color: "#334155", fontWeight: 600 }}>Subject</span>
              </div>
              <input
                value={subject}
                onChange={e => setSubject(e.target.value)}
                placeholder="Email subject"
                style={{
                  flex: 1, background: "transparent", border: "none", outline: "none",
                  fontFamily: "'Outfit',sans-serif", fontSize: 13, color: "#94a3b8",
                }}
              />
            </div>

            {/* Body */}
            <div style={{ position: "relative" }}>
              <textarea
                value={body}
                onChange={e => { if (e.target.value.length <= MAX) setBody(e.target.value); setError(""); setDone(false); setOutput(""); }}
                placeholder="Write your email message here…"
                style={{
                  width: "100%", boxSizing: "border-box", minHeight: 260,
                  padding: "18px 20px", background: "transparent", border: "none", outline: "none", resize: "vertical",
                  fontFamily: "'Outfit',sans-serif", fontSize: 14, color: "#94a3b8", lineHeight: 1.7,
                }}
              />
              <div style={{ position: "absolute", bottom: 10, right: 14 }}>
                <span className="mono" style={{ fontSize: 10, color: body.length > 18000 ? "#ef4444" : "#1e3a5f" }}>
                  {body.length.toLocaleString()}/{MAX.toLocaleString()}
                </span>
              </div>
            </div>

            {error && (
              <div style={{ margin: "0 16px 16px", padding: "10px 14px", borderRadius: 10, background: "#2d0d0d", border: "1px solid #ef444440", display: "flex", alignItems: "center", gap: 8 }}>
                <Icon n="x" s={13} c="#ef4444" />
                <span style={{ fontSize: 12, color: "#f87171" }}>{error}</span>
              </div>
            )}

            {/* Action bar */}
            <div style={{ padding: "14px 20px", borderTop: "1px solid #0f1e2e", background: "#060910", display: "flex", alignItems: "center", gap: 10, flexWrap: "wrap" }}>
              <button onClick={handleProcess} disabled={processing || !body.trim()} style={{
                padding: "10px 22px", borderRadius: 10, border: "none",
                cursor: (processing || !body.trim()) ? "not-allowed" : "pointer",
                background: (processing || !body.trim()) ? "#1e3a5f" : accentGrad,
                color: (processing || !body.trim()) ? "#475569" : "#fff",
                fontFamily: "'Outfit',sans-serif", fontWeight: 700, fontSize: 13,
                display: "flex", alignItems: "center", gap: 7, transition: "all .2s",
              }}>
                {processing
                  ? <div style={{ width: 15, height: 15, border: "2px solid #47556930", borderTopColor: "#94a3b8", borderRadius: "50%", animation: "spin .8s linear infinite" }} />
                  : <Icon n={mode === "encrypt" ? "lock" : "unlock"} s={14} c={(processing || !body.trim()) ? "#475569" : "#fff"} />
                }
                {processing ? (mode === "encrypt" ? "ENCRYPTING…" : "DECRYPTING…") : (mode === "encrypt" ? "ENCRYPT BODY" : "DECRYPT BODY")}
              </button>

              {output && (
                <button onClick={handleSwap} title="Swap output → body" style={{
                  width: 36, height: 36, borderRadius: 10, border: "1px solid #1e2d40",
                  background: "#0a1628", cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center",
                }}>
                  <Icon n="swap" s={15} c="#475569" />
                </button>
              )}

              {mode === "encrypt" && done && (
                <button onClick={handleSend} style={{
                  marginLeft: "auto", padding: "10px 22px", borderRadius: 10, border: "none", cursor: "pointer",
                  background: "linear-gradient(135deg,#10b981,#0ea5e9)",
                  fontFamily: "'Outfit',sans-serif", fontWeight: 700, fontSize: 13, color: "#fff",
                  display: "flex", alignItems: "center", gap: 7,
                }}>
                  <Icon n="send" s={14} c="#fff" /> SEND ENCRYPTED
                </button>
              )}
            </div>
          </div>

          {/* RIGHT: Controls + Output */}
          <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>

            {/* Mode + Algo */}
            <div style={{ background: "#0d1421", border: "1px solid #1e2d40", borderRadius: 16, padding: "18px 20px" }}>
              <p className="mono" style={{ fontSize: 10, color: "#334155", fontWeight: 700, letterSpacing: "0.10em", marginBottom: 14 }}>
                CIPHER SETTINGS
              </p>

              {/* Mode toggle */}
              <div style={{ display: "flex", borderRadius: 10, border: "1px solid #1e2d40", overflow: "hidden", marginBottom: 14 }}>
                {[
                  { id: "encrypt", label: "ENCRYPT", icon: "lock",   color: "#10b981" },
                  { id: "decrypt", label: "DECRYPT", icon: "unlock", color: "#0ea5e9" },
                ].map(m => (
                  <button key={m.id} onClick={() => switchMode(m.id)} style={{
                    flex: 1, padding: "10px", border: "none", cursor: "pointer",
                    fontFamily: "'Outfit',sans-serif", fontWeight: 700, fontSize: 12,
                    letterSpacing: "0.08em", display: "flex", alignItems: "center", justifyContent: "center", gap: 6,
                    transition: "all .2s",
                    background: mode === m.id ? `${m.color}18` : "transparent",
                    color: mode === m.id ? m.color : "#334155",
                    borderBottom: mode === m.id ? `2px solid ${m.color}` : "2px solid transparent",
                  }}>
                    <Icon n={m.icon} s={13} c={mode === m.id ? m.color : "#334155"} />
                    {m.label}
                  </button>
                ))}
              </div>

              {/* Algo */}
              <p style={{ fontSize: 11, color: "#334155", fontWeight: 600, marginBottom: 8 }}>Algorithm</p>
              <div style={{ display: "flex", flexDirection: "column", gap: 6, marginBottom: 16 }}>
                {ALGOS.map(a => (
                  <button key={a} onClick={() => { setAlgo(a); setOutput(""); setDone(false); }} style={{
                    padding: "9px 14px", borderRadius: 10, cursor: "pointer", textAlign: "left",
                    border: algo === a ? "1px solid #0ea5e944" : "1px solid #1e2d40",
                    background: algo === a ? "#0ea5e910" : "#060910",
                    fontFamily: "'JetBrains Mono',monospace", fontSize: 11, fontWeight: 700,
                    color: algo === a ? "#0ea5e9" : "#334155", transition: "all .2s",
                    display: "flex", alignItems: "center", gap: 8,
                  }}>
                    {algo === a && <div style={{ width: 6, height: 6, borderRadius: "50%", background: "#0ea5e9", flexShrink: 0 }} />}
                    {a}
                  </button>
                ))}
              </div>

              {/* Secret key */}
              <p style={{ fontSize: 11, color: "#334155", fontWeight: 600, marginBottom: 8 }}>Secret Key</p>
              <div style={{ position: "relative" }}>
                <input
                  type={showKey ? "text" : "password"}
                  value={secretKey}
                  onChange={e => setKey(e.target.value)}
                  placeholder="Passphrase (blank = default)"
                  style={{
                    width: "100%", boxSizing: "border-box", padding: "10px 40px 10px 14px",
                    background: "#060910", border: "1px solid #1e2d40", borderRadius: 10, outline: "none",
                    fontFamily: "'JetBrains Mono',monospace", fontSize: 12, color: "#94a3b8",
                  }}
                />
                <button onClick={() => setShowKey(v => !v)} style={{ position: "absolute", right: 10, top: "50%", transform: "translateY(-50%)", background: "none", border: "none", cursor: "pointer", display: "flex" }}>
                  <Icon n={showKey ? "eyeoff" : "eye"} s={15} c="#475569" />
                </button>
              </div>
            </div>

            {/* Output panel */}
            <div style={{ background: "#0d1421", border: `1px solid ${done ? modeAccent + "55" : "#1e2d40"}`, borderRadius: 16, overflow: "hidden", transition: "border-color .3s" }}>
              <div style={{ padding: "13px 16px", borderBottom: "1px solid #0f1e2e", background: "#060910", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                  <div style={{ width: 26, height: 26, borderRadius: 7, background: done ? modeAccent + "18" : "#1e2d4022", border: `1px solid ${done ? modeAccent + "44" : "#1e2d40"}`, display: "flex", alignItems: "center", justifyContent: "center", transition: "all .3s" }}>
                    <Icon n={mode === "encrypt" ? "lock" : "mail"} s={12} c={done ? modeAccent : "#334155"} />
                  </div>
                  <span className="mono" style={{ fontSize: 10, color: done ? modeAccent : "#334155", fontWeight: 700, transition: "color .3s" }}>
                    {mode === "encrypt" ? "ENCRYPTED OUTPUT" : "DECRYPTED OUTPUT"}
                  </span>
                </div>
                <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
                  {output && <span className="mono" style={{ fontSize: 10, color: "#334155" }}>{output.length.toLocaleString()} chars</span>}
                  <CopyBtn text={output} small />
                </div>
              </div>

              <div style={{ minHeight: 180, padding: "14px 16px", display: "flex", alignItems: output ? "flex-start" : "center", justifyContent: output ? "flex-start" : "center" }}>
                {output ? (
                  <pre style={{
                    margin: 0, whiteSpace: "pre-wrap", wordBreak: "break-all", flex: 1,
                    fontFamily: mode === "encrypt" ? "'JetBrains Mono',monospace" : "'Outfit',sans-serif",
                    fontSize: mode === "encrypt" ? 11 : 13,
                    color: modeAccent + "cc", lineHeight: 1.6,
                  }}>{output}</pre>
                ) : (
                  <div style={{ textAlign: "center", opacity: 0.3 }}>
                    <div style={{ fontSize: 28, marginBottom: 6 }}>{mode === "encrypt" ? "🔏" : "📧"}</div>
                    <p className="mono" style={{ fontSize: 10, color: "#1e3a5f", margin: 0 }}>
                      {processing ? "PROCESSING…" : "OUTPUT APPEARS HERE"}
                    </p>
                  </div>
                )}
              </div>
            </div>

            {/* Success toast inline */}
            {done && (
              <div className="fade-up" style={{ padding: "12px 16px", borderRadius: 12, background: "#052e16", border: "1px solid #10b98133", display: "flex", alignItems: "center", gap: 10 }}>
                <div style={{ width: 28, height: 28, borderRadius: "50%", background: "#064e3b", border: "1px solid #10b981", flexShrink: 0, display: "flex", alignItems: "center", justifyContent: "center" }}>
                  <Icon n="check" s={13} c="#10b981" />
                </div>
                <div style={{ flex: 1 }}>
                  <p style={{ fontSize: 12, fontWeight: 700, color: "#4ade80", margin: 0 }}>
                    {mode === "encrypt" ? "Body encrypted! Ready to send." : "Body decrypted successfully!"}
                  </p>
                  <p className="mono" style={{ fontSize: 10, color: "#10b98199", marginTop: 2 }}>
                    {algo} · {output.length.toLocaleString()} chars
                  </p>
                </div>
              </div>
            )}
          </div>
        </div>
      )}

      {/* ════════════════════════════════
          INBOX / SENT TAB
      ════════════════════════════════ */}
      {tab === "inbox" && (
        <div className="fade-up">
          {emails.length === 0 ? (
            <div style={{ textAlign: "center", padding: "60px 0", opacity: 0.4 }}>
              <Icon n="inbox" s={44} c="#1e3a5f" />
              <p className="mono" style={{ fontSize: 12, color: "#1e3a5f", marginTop: 14 }}>
                NO SENT EMAILS YET
              </p>
              <p style={{ fontSize: 13, color: "#334155", marginTop: 6 }}>
                Compose and send an encrypted email to see it here.
              </p>
            </div>
          ) : (
            <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
              {/* Info banner */}
              <div style={{ padding: "12px 16px", borderRadius: 12, background: "#0c1a3a", border: "1px solid #0ea5e920", display: "flex", alignItems: "center", gap: 10 }}>
                <Icon n="info" s={14} c="#0ea5e9" />
                <span style={{ fontSize: 12, color: "#0ea5e9" }}>
                  Expand any email to view the encrypted body or decrypt it inline.
                </span>
              </div>

              {emails.map(email => (
                <EmailCard
                  key={email.id}
                  email={email}
                  onDecrypt={(body) => handleInboxDecrypt(email.id, body)}
                  onDelete={() => setEmails(prev => prev.filter(e => e.id !== email.id))}
                />
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  );
}

        <select value={algo} onChange={e => setAlgo(e.target.value)} style={{
          background: "#0d1421", border: "1px solid #1e2d40", borderRadius: 8,
          padding: "8px 12px", fontFamily: "'JetBrains Mono',monospace", fontSize: 11,
          color: "#64748b", outline: "none", cursor: "pointer",
        }}>
          {ALGOS.map(a => <option key={a} value={a}>{a}</option>)}
        </select>
        <div style={{ flex: 1, minWidth: 180, position: "relative" }}>
          <input
            type={show ? "text" : "password"}
            value={key}
            onChange={e => { setKey(e.target.value); setErr(""); }}
            placeholder="Secret key used to encrypt"
            style={{
              width: "100%", boxSizing: "border-box", padding: "8px 40px 8px 12px",
              background: "#0d1421", border: `1px solid ${err ? "#ef444440" : "#1e2d40"}`,
              borderRadius: 8, outline: "none",
              fontFamily: "'JetBrains Mono',monospace", fontSize: 12, color: "#94a3b8",

/* ══════════════════════════════════════════════
   CIPHER ENGINE
══════════════════════════════════════════════ */
function xorCipher(text, key) {
  let out = "";
  for (let i = 0; i < text.length; i++)
    out += String.fromCharCode(text.charCodeAt(i) ^ key.charCodeAt(i % key.length));
  return out;
}

function resolveKey(key, algo) {
  const base = key || "cryptify-default";
  if (algo === "AES-256-GCM") return "AES256GCM::" + base;
  if (algo === "ChaCha20")    return "CHACHA20::"   + base;
  return base;
}

function encryptText(text, key, algo) {
  try { return btoa(unescape(encodeURIComponent(xorCipher(text, resolveKey(key, algo))))); }
  catch { return null; }
}

function decryptText(text, key, algo) {
  try {
    const raw = decodeURIComponent(escape(atob(text.trim())));
    return { ok: true, result: xorCipher(raw, resolveKey(key, algo)) };
  } catch { return { ok: false, result: "Invalid ciphertext — check algorithm and key." }; }
}

/* ══════════════════════════════════════════════
   COPY BUTTON
══════════════════════════════════════════════ */
const CopyBtn = ({ text, small = false }) => {
  const [copied, setCopied] = useState(false);
  const copy = () => {
    if (!text) return;
    navigator.clipboard.writeText(text).then(() => {
      setCopied(true); setTimeout(() => setCopied(false), 2000);
    });
  };
  return (
    <button onClick={copy} disabled={!text} style={{
      display: "flex", alignItems: "center", gap: 5,
      padding: small ? "4px 9px" : "5px 12px",
      borderRadius: 8,
      border: `1px solid ${copied ? "#10b98144" : "#1e3a5f"}`,
      background: copied ? "#052e16" : "#0a1628",
      cursor: text ? "pointer" : "not-allowed",
      fontFamily: "'JetBrains Mono',monospace",
      fontSize: small ? 9 : 10,
      color: copied ? "#10b981" : "#475569", fontWeight: 700,
      opacity: text ? 1 : 0.4, transition: "all .2s",
    }}>
      <Icon n={copied ? "check" : "copy"} s={small ? 10 : 11} c={copied ? "#10b981" : "#475569"} />
      {copied ? "COPIED!" : "COPY"}
    </button>
  );
};

const ALGOS = ["AES-256-GCM", "ChaCha20", "XOR-Base64"];

/* ══════════════════════════════════════════════
   TAG INPUT (recipients)
══════════════════════════════════════════════ */
const TagInput = ({ label, icon, tags, setTags, placeholder }) => {
  const [val, setVal] = useState("");
  const inputRef = useRef(null);

  const addTag = () => {
    const trimmed = val.trim();
    if (trimmed && !tags.includes(trimmed)) {
      setTags([...tags, trimmed]);
    }
    setVal("");
  };

  const onKey = (e) => {
    if (["Enter", ",", "Tab"].includes(e.key)) { e.preventDefault(); addTag(); }
    if (e.key === "Backspace" && !val && tags.length) {
      setTags(tags.slice(0, -1));
    }
  };

  return (
    <div style={{ display: "flex", alignItems: "flex-start", borderBottom: "1px solid #0f1e2e", padding: "12px 20px", gap: 10 }}>
      <div style={{ display: "flex", alignItems: "center", gap: 6, minWidth: 60, paddingTop: 2 }}>
        <Icon n={icon} s={13} c="#334155" />
        <span style={{ fontSize: 12, color: "#334155", fontWeight: 600 }}>{label}</span>
      </div>
      <div
        style={{ flex: 1, display: "flex", flexWrap: "wrap", gap: 6, alignItems: "center", cursor: "text" }}
        onClick={() => inputRef.current?.focus()}
      >
        {tags.map((t, i) => (
          <span key={i} style={{
            display: "flex", alignItems: "center", gap: 5,
            padding: "3px 10px 3px 10px", borderRadius: 20,
            background: "#10b98118", border: "1px solid #10b98133",
            fontSize: 12, color: "#10b981", fontFamily: "'JetBrains Mono',monospace",
          }}>
            {t}
            <span
              onClick={(e) => { e.stopPropagation(); setTags(tags.filter((_, j) => j !== i)); }}
              style={{ cursor: "pointer", display: "flex", marginLeft: 2 }}
            >
              <Icon n="x" s={10} c="#10b981" />
            </span>
          </span>
        ))}
        <input
          ref={inputRef}
          value={val}
          onChange={e => setVal(e.target.value)}
          onKeyDown={onKey}
          onBlur={addTag}
          placeholder={tags.length === 0 ? placeholder : ""}
          style={{
            background: "transparent", border: "none", outline: "none",
            fontFamily: "'Outfit',sans-serif", fontSize: 13, color: "#94a3b8",
            minWidth: 160, flex: 1,
          }}
        />
      </div>
    </div>
  );
};


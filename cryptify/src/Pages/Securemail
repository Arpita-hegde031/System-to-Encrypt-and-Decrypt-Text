            <Icon n={show ? "eyeoff" : "eye"} s={14} c="#475569" />
          </button>
        </div>
        <button onClick={handle} style={{
          padding: "8px 20px", borderRadius: 10, border: "none", cursor: "pointer",
          background: "linear-gradient(135deg,#0ea5e9,#a78bfa)",
